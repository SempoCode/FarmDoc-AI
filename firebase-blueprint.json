{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Consultation": {
      "title": "Consultation",
      "description": "A crop consultation record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "crop": { "type": "string" },
        "problem": { "type": "string" },
        "response": { "type": "string" },
        "timestamp": { "type": "number" },
        "language": { "type": "string", "enum": ["en", "sw"] }
      },
      "required": ["uid", "crop", "problem", "response", "timestamp", "language"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/consultations/{consultationId}": {
      "schema": "Consultation",
      "description": "Consultation records"
    }
  }
}
